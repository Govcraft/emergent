import asyncio

from emergent import run_handler, create_message


async def process_message(msg, handler):
    """Process each incoming message."""
    # TODO: Add your processing logic here
    await handler.publish(
        create_message("{{ publishes[0] if publishes else "handler.output" }}")
        .caused_by(msg.id)
        .payload({
            "processed": True,
            "original_type": msg.message_type,
        })
    )


if __name__ == "__main__":
    asyncio.run(
        run_handler(
            "{{ name }}",
            [{% for sub in subscribes %}"{{ sub }}"{% if not loop.last %}, {% endif %}{% endfor %}],
            process_message,
        )
    )
