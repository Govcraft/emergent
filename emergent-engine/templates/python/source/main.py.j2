#!/usr/bin/env python3
"""{{ name_pascal }} Source

{{ description }}

Publishes:
{% for pub in publishes %}
- {{ pub }}
{% endfor %}
"""

import asyncio

from emergent import run_source, create_message


async def source_logic(source, shutdown_event):
    """Publish events until shutdown is requested."""
    sequence = 0
    while not shutdown_event.is_set():
        try:
            await asyncio.wait_for(shutdown_event.wait(), timeout=1.0)
            break  # Shutdown requested
        except asyncio.TimeoutError:
            sequence += 1
            await source.publish(
                create_message("{{ publishes[0] if publishes else "source.event" }}")
                .payload({"sequence": sequence})
            )


if __name__ == "__main__":
    asyncio.run(run_source("{{ name }}", source_logic))
