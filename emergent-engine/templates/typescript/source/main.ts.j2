#!/usr/bin/env -S deno run --allow-env --allow-read --allow-net=unix
/**
 * {{ name_pascal }} Source
 *
 * {{ description }}
 *
 * Publishes:
{% for pub in publishes %}
 * - {{ pub }}
{% endfor %}
 */

import { runSource, createMessage } from "@govcraft/emergent";

await runSource("{{ name }}", async (source, shutdown) => {
  let sequence = 0;

  const intervalId = setInterval(async () => {
    if (shutdown.aborted) return;
    sequence++;
    await source.publish(
      createMessage("{{ publishes[0] if publishes else "source.event" }}")
        .payload({ sequence, timestamp: Date.now() })
    );
  }, 1000);

  // Wait for shutdown signal
  await new Promise<void>((resolve) => {
    shutdown.addEventListener("abort", () => {
      clearInterval(intervalId);
      resolve();
    });
  });
});
